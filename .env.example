# config do firebase do shakeit
# copie esse arquivo para .env e preencha os valores com as chaves do seu projeto firebase

EXPO_PUBLIC_FIREBASE_API_KEY=valor_da_sua_chave_aqui
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=valor_da_sua_chave_aqui
EXPO_PUBLIC_FIREBASE_PROJECT_ID=valor_da_sua_chave_aqui
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=valor_da_sua_chave_aqui
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=valor_da_sua_chave_aqui
EXPO_PUBLIC_FIREBASE_APP_ID=valor_da_sua_chave_aqui
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=valor_da_sua_chave_aqui